{
    "$schema":  "https://json-schema.org/draft/2020-12/schema",
    "$id":  "https://rakuai.com/schema/raku-file-v1.json",
    "title":  "Raku Game File",
    "description":  "Schema for .raku game definition files. AI assistants generate these from natural language.",
    "type":  "object",
    "required":  [
                     "raku_format",
                     "metadata",
                     "initialization",
                     "calls",
                     "shutdown"
                 ],
    "properties":  {
                       "raku_format":  {
                                           "type":  "string",
                                           "const":  "1.0.0"
                                       },
                       "metadata":  {
                                        "$ref":  "#/$defs/Metadata"
                                    },
                       "initialization":  {
                                              "type":  "array",
                                              "description":  "Engine init calls. Must start with raku_init.",
                                              "items":  {
                                                            "$ref":  "#/$defs/ApiCall"
                                                        },
                                              "minItems":  1
                                          },
                       "calls":  {
                                     "type":  "array",
                                     "description":  "Gameplay calls. Must end with raku_scene_start_loop.",
                                     "items":  {
                                                   "$ref":  "#/$defs/ApiCall"
                                               },
                                     "minItems":  1
                                 },
                       "shutdown":  {
                                        "type":  "array",
                                        "description":  "Cleanup. Must end with raku_shutdown.",
                                        "items":  {
                                                      "$ref":  "#/$defs/ApiCall"
                                                  },
                                        "minItems":  1
                                    }
                   },
    "$defs":  {
                  "Metadata":  {
                                   "type":  "object",
                                   "required":  [
                                                    "name",
                                                    "description",
                                                    "genre",
                                                    "creator",
                                                    "version"
                                                ],
                                   "properties":  {
                                                      "name":  {
                                                                   "type":  "string"
                                                               },
                                                      "description":  {
                                                                          "type":  "string"
                                                                      },
                                                      "genre":  {
                                                                    "type":  "string",
                                                                    "enum":  [
                                                                                 "space_shooter",
                                                                                 "tower_defense",
                                                                                 "puzzle",
                                                                                 "platformer",
                                                                                 "arena_combat",
                                                                                 "racing",
                                                                                 "rhythm",
                                                                                 "roguelike",
                                                                                 "survival",
                                                                                 "rpg",
                                                                                 "sandbox",
                                                                                 "tech_demo",
                                                                                 "custom"
                                                                             ]
                                                                },
                                                      "creator":  {
                                                                      "type":  "string"
                                                                  },
                                                      "created":  {
                                                                      "type":  "string",
                                                                      "format":  "date-time"
                                                                  },
                                                      "version":  {
                                                                      "type":  "string"
                                                                  },
                                                      "engine_version":  {
                                                                             "type":  "string"
                                                                         },
                                                      "sharing":  {
                                                                      "type":  "string",
                                                                      "enum":  [
                                                                                   "public",
                                                                                   "private",
                                                                                   "unlisted"
                                                                               ],
                                                                      "default":  "public"
                                                                  },
                                                      "tags":  {
                                                                   "type":  "array",
                                                                   "items":  {
                                                                                 "type":  "string"
                                                                             }
                                                               },
                                                      "runtime_version_min":  {
                                                                                  "type":  "string"
                                                                              },
                                                      "complexity":  {
                                                                         "type":  "string",
                                                                         "enum":  [
                                                                                      "low",
                                                                                      "medium",
                                                                                      "high"
                                                                                  ]
                                                                     },
                                                      "content_pack":  {
                                                                           "type":  "object",
                                                                           "description":  "References a first-party content pack for curated assets.",
                                                                           "properties":  {
                                                                               "template":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Template family (e.g. space_shooter, platformer)."
                                                                               },
                                                                               "mode":  {
                                                                                   "type":  "string",
                                                                                   "enum":  ["prototype", "presentation"],
                                                                                   "description":  "Prototype for fast iteration; presentation for polished demos."
                                                                               },
                                                                               "pack_version":  {
                                                                                   "type":  "string",
                                                                                   "description":  "Minimum pack version required."
                                                                               }
                                                                           },
                                                                           "required":  ["template", "mode"]
                                                                       },
                                                      "audio_plan":  {
                                                                         "type":  "object",
                                                                         "description":  "Declares audio asset mapping for adaptive music and SFX.",
                                                                         "properties":  {
                                                                             "music":  {
                                                                                 "type":  "object",
                                                                                 "properties":  {
                                                                                     "main_loop":  {"type":  "string"},
                                                                                     "intensity_layers":  {"type":  "array", "items":  {"type":  "string"}}
                                                                                 }
                                                                             },
                                                                             "sfx":  {
                                                                                 "type":  "object",
                                                                                 "properties":  {
                                                                                     "weapon_fire":  {"type":  "string"},
                                                                                     "impact":  {"type":  "string"},
                                                                                     "explosion":  {"type":  "string"},
                                                                                     "pickup":  {"type":  "string"},
                                                                                     "warning":  {"type":  "string"}
                                                                                 }
                                                                             },
                                                                             "ui":  {
                                                                                 "type":  "object",
                                                                                 "properties":  {
                                                                                     "click":  {"type":  "string"},
                                                                                     "confirm":  {"type":  "string"},
                                                                                     "error":  {"type":  "string"}
                                                                                 }
                                                                             }
                                                                         }
                                                                     }
                                                  }
                               },
                  "ApiCall":  {
                                  "type":  "object",
                                  "required":  [
                                                   "function",
                                                   "params"
                                               ],
                                  "properties":  {
                                                     "function":  {
                                                                      "type":  "string",
                                                                      "pattern":  "^raku_[a-z_]+$",
                                                                      "description":  "C API function: raku_<module>_<action>."
                                                                  },
                                                     "params":  {
                                                                    "type":  "object"
                                                                }
                                                 }
                              },
                  "SubsystemReference":  {
                                             "description":  "Engine subsystems available for game creation. See NDA documentation for details.",
                                             "type": "string"
                                         }
              },
    "examples_note": "Runtime Format examples with full API call sequences are available under NDA. Contact https://rakuai.com/contact.html for access. Standard Format examples are available in the samples directory.",
    "ai_safety": {
        "description": "Safety guidelines for AI platforms generating .raku files",
        "requires_user_confirmation": [
            "Network initialization — enables network access",
            "XR initialization — activates XR hardware",
            "Voice initialization — enables microphone access"
        ],
        "rate_limiting": "Recommended: max 100 API calls per .raku file for standard game creation workflows",
        "excluded_apis": "This schema exposes game creation APIs only. Engine internals, memory management, and low-level rendering are intentionally excluded."
    }
}